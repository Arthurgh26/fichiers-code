print("--- Calculateur Solaire ---")
puissance_panneau = float(input("Quelle est la puissance du panneau ?"))
heures_soleil = float(input("Combien d'heures de soleil aujourd'hui ?"))

production = puissance_panneau * heures_soleil

print(f"Aujourd'hui, tu as produit {production} Wh.")

production_kWh = production * 0.001

prix_kWh = float(input("Quel est le prix du kWh ?"))

economie = production_kWh * prix_kWh

print(f"Ajourd'hui tu as économisé {economie} euros.")
